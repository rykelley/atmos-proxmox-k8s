# Copy to .env and fill in. Source it before running atmos:  set -a; . ./.env; set +a
#
# --- Proxmox (bpg/proxmox provider) ---
# API endpoint of your Proxmox VE host/cluster.
export PROXMOX_VE_ENDPOINT="https://proxmox.example.com:8006/"
# Recommended: API token in the form USER@REALM!TOKENID=UUID
export PROXMOX_VE_API_TOKEN="root@pam!atmos=00000000-0000-0000-0000-000000000000"
# Alternatively use username/password instead of an API token:
# export PROXMOX_VE_USERNAME="root@pam"
# export PROXMOX_VE_PASSWORD="changeme"
# Allow self-signed certs on the Proxmox API (set to true for typical home labs).
export PROXMOX_VE_INSECURE="true"
# SSH connection the provider uses for file uploads / agent operations.
export PROXMOX_VE_SSH_USERNAME="root"

# --- Ansible ---
# Private key matching the public key injected into the VMs via cloud-init.
export ANSIBLE_PRIVATE_KEY_FILE="${HOME}/.ssh/id_ed25519"
export ANSIBLE_HOST_KEY_CHECKING="false"

# --- Ansible Vault (for the k3s join token) ---
# Path to a file containing the vault password used to decrypt group_vars secrets.
export ANSIBLE_VAULT_PASSWORD_FILE="${HOME}/.config/atmos-k3s/vault-pass"
