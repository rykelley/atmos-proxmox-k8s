# Filament Tracker - local/dev environment.
# Copy to .env in each service/web dir (or export) before running locally.

# --- Supabase Cloud Postgres (used by catalog-service and inventory-service) ---
# Prefer the connection pooler URL (port 6543, transaction mode). prepare=false
# is set in code because the transaction pooler does not support prepared stmts.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# --- Service ports ---
PORT=8080

# --- web (Next.js) BFF: internal service base URLs ---
# In-cluster these resolve to the ClusterIP services. Locally, point at the
# ports you run the services on.
CATALOG_URL="http://localhost:8081"
INVENTORY_URL="http://localhost:8082"
